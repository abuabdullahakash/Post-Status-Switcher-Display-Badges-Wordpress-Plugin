rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Configured for instant demo setup: allows read and write to all collections.
    // This allows your local admin fallback (mdakash136915@gmail.com) to save and update
    // features, pricing, and settings instantly on Vercel without configuring Firebase Auth.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
