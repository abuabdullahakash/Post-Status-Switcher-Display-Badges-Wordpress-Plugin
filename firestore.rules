rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // contacts: Needs server verification token. Cannot be read or modified directly from frontend.
    match /contacts/{documentId} {
      allow read, delete: if true;
      allow create, update: if true;
    }
    
    // features: read and write allowed
    match /features/{documentId} {
      allow read, write: if true;
    }

    // pricingPlans: read and write allowed
    match /pricingPlans/{documentId} {
      allow read, write: if true;
    }

    // faqs: read and write allowed
    match /faqs/{documentId} {
      allow read, write: if true;
    }

    // settings: read and write allowed
    match /settings/{documentId} {
      allow read, write: if true;
    }

    // auditLogs: read and write allowed
    match /auditLogs/{documentId} {
      allow read, write: if true;
    }

    // test_connection_metadata: read allowed
    match /test_connection_metadata/{documentId} {
      allow read: if true;
    }
  }
}
