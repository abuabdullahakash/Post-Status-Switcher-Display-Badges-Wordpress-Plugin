{
  "entities": {
    "feature": {
      "title": "Module Feature",
      "description": "Represents a Post Status and Badge feature card.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "iconName": { "type": "string" },
        "color": { "type": "string" },
        "useCase": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "description", "iconName", "color", "useCase", "active", "order"]
    },
    "pricingPlan": {
      "title": "Pricing Plan",
      "description": "Pricing plan subscription details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "string" },
        "features": {
          "type": "array",
          "description": "List of features included in the plan"
        },
        "popular": { "type": "boolean" },
        "buttonText": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "price", "period", "description", "features", "popular", "buttonText", "order"]
    },
    "faq": {
      "title": "FAQ Item",
      "description": "Frequently Asked Question item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "question", "answer", "order"]
    },
    "setting": {
      "title": "Global Settings",
      "description": "Global custom landing page settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "siteName": { "type": "string" },
        "siteDescription": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroDescription": { "type": "string" },
        "adminEmail": { "type": "string" }
      },
      "required": ["id", "siteName", "siteDescription", "heroTitle", "heroSubtitle", "heroDescription"]
    },
    "integration": {
      "title": "Ecosystem Partner Integration",
      "description": "Compatibility details for a third-party WP framework or plugin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subtitle": { "type": "string" },
        "badge": { "type": "string" },
        "description": { "type": "string" },
        "testedVersion": { "type": "string" },
        "active": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "subtitle", "badge", "description", "testedVersion", "active", "order"]
    },
    "contact": {
      "title": "Contact Submission",
      "description": "Information about support tickets and contact form submissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "serverDispatchSecret": { "type": "string" }
      },
      "required": ["id", "name", "email", "message"]
    },
    "auditLog": {
      "title": "Administrative Audit Log",
      "description": "Records administrative dashboard active state changes and resets.",
      "type": "object",
      "properties": {
        "actionType": { "type": "string" },
        "actionCategory": { "type": "string" },
        "details": { "type": "string" },
        "actor": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["actionType", "actionCategory", "details", "timestamp"]
    }
  },
  "firestore": {
    "/features/{featureId}": {
      "schema": { "$ref": "#/entities/feature" },
      "description": "Collection of all WP Post Status switcher and badge features"
    },
    "/pricingPlans/{planId}": {
      "schema": { "$ref": "#/entities/pricingPlan" },
      "description": "Collection of all pricing plans"
    },
    "/faqs/{faqId}": {
      "schema": { "$ref": "#/entities/faq" },
      "description": "Collection of all FAQs"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/setting" },
      "description": "Collection of settings (usually just 'global' doc)"
    },
    "/integrations/{integrationId}": {
      "schema": { "$ref": "#/entities/integration" },
      "description": "Collection of plugin ecosystem partnerships"
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "#/entities/contact" },
      "description": "Collection of contact forms and inquiries"
    },
    "/auditLogs/{logId}": {
      "schema": { "$ref": "#/entities/auditLog" },
      "description": "Collection of administrative audit log actions"
    }
  }
}
